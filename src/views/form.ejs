<%- include('partials/head', { title: title }) %>

<div class="mb-6">
  <h1 class="text-2xl font-semibold tracking-tight text-slate-900"><%= title %></h1>
  <p class="mt-1 text-sm text-slate-600">
    Los campos vacíos se guardan como vacíos. Servicio admite varias opciones (Ctrl/Cmd + clic).
  </p>
</div>

<form
  action="<%= action %>"
  method="<%= method %>"
  class="space-y-8 rounded-xl border border-slate-200/80 bg-white p-6 shadow-sm sm:p-8"
>
  <section>
    <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-slate-500">
      General
    </h2>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block sm:col-span-2">
        <span class="mb-1 block text-sm font-medium text-slate-700">Comercial</span>
        <input
          type="text"
          name="comercial"
          value="<%= record ? (record.comercial || '') : '' %>"
          class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none ring-slate-400 placeholder:text-slate-400 focus:border-slate-400 focus:ring-2 focus:ring-slate-900/10"
          placeholder="Texto"
        />
      </label>
      <label class="block">
        <span class="mb-1 block text-sm font-medium text-slate-700">Categoría</span>
        <select
          name="categoria"
          class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10"
        >
          <option value="">—</option>
          <% options.categoria.forEach(function (opt) { %>
          <option value="<%= opt %>" <%= record && record.categoria === opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>
      </label>
      <label class="block">
        <span class="mb-1 block text-sm font-medium text-slate-700">Tipo</span>
        <select name="tipo" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10">
          <option value="">—</option>
          <% options.tipo.forEach(function (opt) { %>
          <option value="<%= opt %>" <%= record && record.tipo === opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>
      </label>
      <label class="block sm:col-span-2">
        <span class="mb-1 block text-sm font-medium text-slate-700">Servicio</span>
        <select
          name="servicio"
          multiple
          size="6"
          class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10"
        >
          <% const selectedServ = record && Array.isArray(record.servicio) ? record.servicio : []; %>
          <% options.servicio.forEach(function (opt) { %>
          <option value="<%= opt %>" <%= selectedServ.indexOf(opt) !== -1 ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>
        <span class="mt-1 block text-xs text-slate-500">Multi-selección: mantén Ctrl (Windows) o ⌘ (Mac) al elegir.</span>
      </label>
    </div>
  </section>

  <section>
    <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-slate-500">
      Infraestructura
    </h2>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <label class="block">
        <span class="mb-1 block text-sm font-medium text-slate-700">Nube</span>
        <select name="nube" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10">
          <option value="">—</option>
          <% options.nube.forEach(function (opt) { %>
          <option value="<%= opt %>" <%= record && record.nube === opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>
      </label>
      <label class="block">
        <span class="mb-1 block text-sm font-medium text-slate-700">Status</span>
        <select name="status" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10">
          <option value="">—</option>
          <% options.status.forEach(function (opt) { %>
          <option value="<%= opt %>" <%= record && record.status === opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>
      </label>
      <label class="block">
        <span class="mb-1 block text-sm font-medium text-slate-700">Administración</span>
        <select name="administracion" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10">
          <option value="">—</option>
          <% options.administracion.forEach(function (opt) { %>
          <option value="<%= opt %>" <%= record && record.administracion === opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>
      </label>
      <label class="block">
        <span class="mb-1 block text-sm font-medium text-slate-700">Backup interno</span>
        <select name="backup_interno" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10">
          <option value="">—</option>
          <% options.backup_interno.forEach(function (opt) { %>
          <option value="<%= opt %>" <%= record && record.backup_interno === opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>
      </label>
      <label class="block">
        <span class="mb-1 block text-sm font-medium text-slate-700">Plataforma</span>
        <select name="plataforma" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10">
          <option value="">—</option>
          <% options.plataforma.forEach(function (opt) { %>
          <option value="<%= opt %>" <%= record && record.plataforma === opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>
      </label>
      <label class="block">
        <span class="mb-1 block text-sm font-medium text-slate-700">DC</span>
        <select name="dc" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10">
          <option value="">—</option>
          <% options.dc.forEach(function (opt) { %>
          <option value="<%= opt %>" <%= record && record.dc === opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>
      </label>
      <label class="block">
        <span class="mb-1 block text-sm font-medium text-slate-700">AB</span>
        <select name="ab" class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10">
          <option value="">—</option>
          <% options.ab.forEach(function (opt) { %>
          <option value="<%= opt %>" <%= record && record.ab === opt ? 'selected' : '' %>><%= opt %></option>
          <% }) %>
        </select>
      </label>
    </div>
  </section>

  <section>
    <h2 class="mb-4 text-sm font-semibold uppercase tracking-wide text-slate-500">
      Notas y contacto
    </h2>
    <div class="grid gap-4 sm:grid-cols-2">
      <label class="block sm:col-span-2">
        <span class="mb-1 block text-sm font-medium text-slate-700">Otros</span>
        <textarea
          name="otros"
          rows="3"
          class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10"
          placeholder="Texto libre"
        ><%= record ? (record.otros || '') : '' %></textarea>
      </label>
      <label class="block sm:col-span-2">
        <span class="mb-1 block text-sm font-medium text-slate-700">Contacto</span>
        <input
          type="text"
          name="contacto"
          value="<%= record ? (record.contacto || '') : '' %>"
          class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10"
          placeholder="Persona o texto libre"
        />
      </label>
      <label class="block sm:col-span-2">
        <span class="mb-1 block text-sm font-medium text-slate-700">Columna1</span>
        <input
          type="text"
          name="columna1"
          value="<%= record ? (record.columna1 || '') : '' %>"
          class="w-full rounded-lg border border-slate-200 bg-white px-3 py-2 text-slate-900 shadow-sm outline-none focus:ring-2 focus:ring-slate-900/10"
        />
      </label>
    </div>
  </section>

  <div class="flex flex-wrap items-center gap-3 border-t border-slate-100 pt-6">
    <button
      type="submit"
      class="inline-flex items-center justify-center rounded-lg bg-slate-900 px-5 py-2.5 text-sm font-medium text-white shadow-sm hover:bg-slate-800"
    >
      Guardar
    </button>
    <a
      href="/"
      class="inline-flex items-center justify-center rounded-lg border border-slate-200 bg-white px-5 py-2.5 text-sm font-medium text-slate-700 shadow-sm hover:bg-slate-50"
      >Cancelar</a
    >
  </div>
</form>

<%- include('partials/foot') %>
